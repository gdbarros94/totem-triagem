# Configuração de Portas (Host Linux)
FRONTEND_PORT=8080
BACKEND_PORT=8000

# URL do Backend consumida pelo Frontend.
# Mantenha "/api" se for usar o proxy nativo do Nginx via docker-compose (Recomendado).
# Se for usar domínios separados ou dar bypass no Nginx, coloque a URL absoluta: Ex: "http://meu-ip-ou-dominio:8000/api"
VITE_API_URL=/api

DATABASE_URL=sqlite:///./data/triagem.db
SECRET_KEY=super-secret-key-change-me
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
N8N_WEBHOOK_URL=http://your-n8n-domain.com/webhook/triagem-ia
